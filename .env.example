# ── Core ──────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/intent_trading
REDIS_URL=redis://127.0.0.1:6379
SERVER_ADDR=0.0.0.0:3000
GATEWAY_ADDR=0.0.0.0:4000
UPSTREAM_URL=http://127.0.0.1:3000
JWT_SECRET=change-me-in-production
LOG_LEVEL=info
ENVIRONMENT=dev

# ── Logging & Tracing ────────────────────────────────────
# LOG_FORMAT=json                                    # "json" for structured, unset for text
# OTEL_ENABLED=true                                  # Enable OpenTelemetry tracing
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # Jaeger/OTLP collector
# OTEL_SERVICE_NAME=intentx-trading

# ── EVM Chain RPCs (defaults to llamarpc public endpoints) ──
# ETH_RPC_URL=https://eth.llamarpc.com
# POLYGON_RPC_URL=https://polygon.llamarpc.com
# ARBITRUM_RPC_URL=https://arbitrum.llamarpc.com
# BASE_RPC_URL=https://base.llamarpc.com

# ── Chaos Engineering ────────────────────────────────────
# CHAOS_ENABLED=true                                 # Enable fault injection (DO NOT use in production)

# ── Frontend ─────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:3000
# NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws/feed
# NEXT_PUBLIC_SOLANA_NETWORK=devnet
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Solver Bot ───────────────────────────────────────────
# SERVER_URL=http://127.0.0.1:3000
# WS_URL=ws://127.0.0.1:3000/ws/feed
# SOLVER_ID=solver-bot-alpha
# BID_STRATEGY=balanced                              # aggressive | conservative | balanced
# MAX_POSITION=1000000
# POLL_INTERVAL_MS=100
# API_KEY=                                           # Optional API key for authenticated requests
