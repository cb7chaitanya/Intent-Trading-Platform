{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Platform Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(intents_total[1m]) * 60",
          "legendFormat": "Intents / min"
        }
      ],
      "title": "Intents per Minute",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "active_auctions",
          "legendFormat": "Active"
        }
      ],
      "title": "Active Auctions",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "unit": "none"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "websocket_connections",
          "legendFormat": "Connections"
        }
      ],
      "title": "WebSocket Connections",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 200,
      "title": "Trading Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(trades_executed_counter[1m])",
          "legendFormat": "Trades / sec"
        }
      ],
      "title": "Trades per Second",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "normal" } },
          "unit": "none"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 9 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(trade_volume_total[5m]) * 300",
          "legendFormat": "{{ market_id }}"
        }
      ],
      "title": "Volume per Market (5m window)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "unit": "none"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 9 },
      "id": 6,
      "targets": [
        {
          "expr": "increase(fees_collected_total[1h])",
          "legendFormat": "Fees / hour"
        }
      ],
      "title": "Fees Collected per Hour",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 16 },
      "id": 7,
      "targets": [
        {
          "expr": "topk(10, solver_wins_total)",
          "legendFormat": "{{ solver_id }}"
        }
      ],
      "title": "Solver Win Rate (Top 10)",
      "type": "bargauge",
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "unit": "none"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 16 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "bids_per_auction_latest",
          "legendFormat": "Bids"
        }
      ],
      "title": "Bids in Latest Auction",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 300,
      "title": "Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 24 },
      "id": 9,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 all endpoints"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(api_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50 all endpoints"
        }
      ],
      "title": "API Latency (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 24 },
      "id": 10,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(matching_engine_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(matching_engine_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "title": "Matching Engine Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 24 },
      "id": 11,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(auction_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(auction_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "rate(auction_duration_seconds_sum[5m]) / rate(auction_duration_seconds_count[5m])",
          "legendFormat": "avg"
        }
      ],
      "title": "Auction Duration",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 31 },
      "id": 12,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p95 {{ endpoint }}"
        }
      ],
      "title": "API Latency by Endpoint (p95)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 400,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "fillOpacity": 30, "lineWidth": 2 },
          "unit": "none"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 39 },
      "id": 13,
      "targets": [
        {
          "expr": "increase(settlement_failures_total[5m])",
          "legendFormat": "Failures / 5m"
        }
      ],
      "title": "Settlement Failures",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 39 },
      "id": 14,
      "targets": [
        {
          "expr": "sum(rate(api_requests_total{status=~\"5..\"}[5m])) / sum(rate(api_requests_total[5m]))",
          "legendFormat": "5xx rate"
        },
        {
          "expr": "sum(rate(api_requests_total{status=~\"4..\"}[5m])) / sum(rate(api_requests_total[5m]))",
          "legendFormat": "4xx rate"
        }
      ],
      "title": "API Error Rates",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 39 },
      "id": 15,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "settlement_success_total / (settlement_success_total + settlement_failures_total)",
          "legendFormat": "Success rate"
        }
      ],
      "title": "Settlement Success Rate",
      "type": "gauge"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "id": 500,
      "title": "Infrastructure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 47 },
      "id": 16,
      "targets": [
        {
          "expr": "sum(rate(api_requests_total[1m])) by (method)",
          "legendFormat": "{{ method }}"
        }
      ],
      "title": "API Requests per Second by Method",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 47 },
      "id": 17,
      "targets": [
        {
          "expr": "topk(10, sum(rate(api_requests_total[5m])) by (endpoint))",
          "legendFormat": "{{ endpoint }}"
        }
      ],
      "title": "Top 10 Endpoints by Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 54 },
      "id": 18,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "trades_total",
          "legendFormat": "Total"
