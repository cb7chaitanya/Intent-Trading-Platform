      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 54 },
      "id": 19,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "intents_total",
          "legendFormat": "Total"
        }
      ],
      "title": "Total Intents (All Time)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 54 },
      "id": 20,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "bids_total",
          "legendFormat": "Total"
        }
      ],
      "title": "Total Bids (All Time)",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["trading", "intent-platform", "prometheus"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
